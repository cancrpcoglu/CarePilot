# Uygulama
PROJECT_NAME=CarePilot
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# Veritabanı (asyncpg sürücüsü zorunlu)
DATABASE_URL=postgresql+asyncpg://carepilot:carepilot@localhost:5432/carepilot

# Güvenlik / JWT — production'da MUTLAKA uzun, rastgele bir değerle değiştir
JWT_SECRET_KEY=change-me-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Yapay Zeka (Gemini) — Sprint 2'de kullanılacak
GEMINI_API_KEY=

# CORS — JSON dizi formatında
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
